{
  "rules": {
    "preset-ja-technical-writing": {
      "sentence-length": { "max": 100 },
      "max-comma": { "max": 4 },
      "max-ten": { "max": 3 },
      "max-kanji-continuous-len": { "max": 6 },
      "no-mix-dearu-desumasu": {
        "preferInHeader": "",
        "preferInBody": "ですます",
        "preferInList": "ですます",
        "strict": false
      },
      "ja-no-mixed-period": { "periodMark": "。" },
      "no-double-negative-ja": true,
      "no-dropping-the-ra": true,
      "no-doubled-joshi": { "strict": false, "allow": ["も"] },
      "no-doubled-conjunctive-particle-ga": true,
      "no-doubled-conjunction": true,
      "no-exclamation-question-mark": {
        "allowFullWidthExclamation": false,
        "allowFullWidthQuestion": false
      }
    },
    "preset-ja-spacing": {
      "ja-space-between-half-and-full-width": { "space": "always" },
      "ja-space-around-code": { "before": true, "after": true }
    }
  }
}
