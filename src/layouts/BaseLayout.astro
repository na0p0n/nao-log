---
interface Props {
  title: string;
  description?: string;
  image?: string;
  pubDate?: Date;
  updatedDate?: Date;
  type?: 'website' | 'article';
  tags?: string[];
}

const {
  title,
  description,
  image,
  pubDate,
  updatedDate,
  type = 'website',
  tags = [],
} = Astro.props;

const siteName = 'Nao Log';
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;

// base: '/nao-log' なので Astro.url.pathname はベースパスを含む
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// public/ 配下のアセットはデプロイ後にベースパス配下で配信される
const baseURL = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const siteWithBase = `${Astro.site?.toString().replace(/\/$/, '')}${baseURL}`;
const resolveAsset = (path: string) =>
  path.startsWith('http')
    ? path
    : new URL(path.replace(/^\//, ''), siteWithBase).toString();
const ogImage = resolveAsset(image ?? 'og-default.png');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${baseURL}favicon.svg`} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    {pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {tags.map((t) => <meta property="article:tag" content={t} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    {type === 'article' && (
      <script is:inline>
        document.addEventListener('DOMContentLoaded', async () => {
          const pres = document.querySelectorAll('pre[data-language="mermaid"]');
          if (!pres.length) return;
          const { default: mermaid } = await import(
            'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs'
          );
          mermaid.initialize({
            startOnLoad: false,
            theme: 'base',
            themeVariables: {
              primaryColor: '#dbeafe',
              primaryTextColor: '#1a1a1a',
              primaryBorderColor: '#0969da',
              lineColor: '#6b7280',
              secondaryColor: '#eff6ff',
              tertiaryColor: '#f0f9ff',
              fontFamily: 'system-ui, -apple-system, "Hiragino Sans", "Noto Sans JP", sans-serif',
            },
            securityLevel: 'loose',
          });
          pres.forEach((pre) => {
            const div = document.createElement('div');
            div.className = 'mermaid';
            div.textContent = pre.textContent;
            pre.replaceWith(div);
          });
          await mermaid.run();
        });
      </script>
    )}
  </head>
  <body>
    <header class="site-header">
      <nav class="header-nav">
        <a href={baseURL} class="site-title"><strong>{siteName}</strong></a>
        <div class="nav-links">
          <a href={baseURL}>Home</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>© {new Date().getFullYear()} {siteName}</small>
    </footer>
    <style is:global>
      :root {
        /* Color palette */
        --fg: #1a1a1a;
        --bg: #f0f4f8;
        --card-bg: #ffffff;
        --bg-alt: #1a1a2e;
        --border: #d0d7de;
        --muted: #656d76;
        --muted-light: #9198a1;
        --accent: #0969da;
        --accent-hover: #0550ae;
        --tag-bg: #0969da;
        --tag-text: #ffffff;

        /* Spacing */
        --space-xs: 0.5rem;
        --space-sm: 1rem;
        --space-md: 1.5rem;
        --space-lg: 2rem;
        --space-xl: 3rem;

        /* Borders & shadows */
        --radius: 4px;
        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.07);

        /* Typography scale */
        --text-xs: 0.75rem;
        --text-sm: 0.875rem;
        --text-base: 1rem;
        --text-lg: 1.125rem;
        --text-xl: 1.25rem;
        --text-2xl: 1.5rem;
        --text-3xl: 1.875rem;

        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          "Hiragino Sans",
          "Noto Sans JP",
          sans-serif;
      }
      body {
        margin: 0;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.75;
      }
      .site-header {
        background: var(--bg-alt);
      }
      .header-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-md) var(--space-sm);
      }
      .site-title {
        font-size: var(--text-xl);
        text-decoration: none;
        color: #ffffff;
        letter-spacing: -0.02em;
      }
      .site-title:hover {
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
      }
      .nav-links {
        display: flex;
        gap: var(--space-md);
        font-size: var(--text-sm);
      }
      .nav-links a {
        color: rgba(255, 255, 255, 0.65);
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: #ffffff;
        text-decoration: none;
      }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      footer {
        max-width: 720px;
        margin: 0 auto;
        padding: 1rem;
        color: var(--muted);
        border-top: 1px solid var(--border);
        margin-top: 4rem;
      }
      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.2s;
      }
      a:hover {
        color: var(--accent-hover);
        text-decoration: underline;
      }
      h1 {
        font-size: var(--text-3xl);
        line-height: 1.3;
        margin: var(--space-md) 0 var(--space-sm) 0;
      }
      h2 {
        font-size: var(--text-2xl);
        line-height: 1.3;
        margin: var(--space-lg) 0 var(--space-sm) 0;
      }
      h3 {
        font-size: var(--text-xl);
        line-height: 1.3;
        margin: var(--space-md) 0 var(--space-sm) 0;
      }
      h4,
      h5,
      h6 {
        line-height: 1.3;
        margin: var(--space-md) 0 var(--space-sm) 0;
      }
      pre {
        padding: 1rem;
        border-radius: var(--radius);
        overflow-x: auto;
        background: #f5f5f5;
        border: 1px solid var(--border);
      }
      code {
        font-family: "SFMono-Regular", Consolas, monospace;
        font-size: 0.9em;
      }
      article time {
        color: var(--muted);
        font-size: 0.9em;
      }
      blockquote {
        border-left: 4px solid var(--accent);
        padding-left: var(--space-md);
        margin-left: 0;
        color: var(--muted);
        font-style: italic;
      }
      .mermaid {
        text-align: center;
        margin: 2rem auto;
        overflow-x: auto;
      }
      .mermaid svg {
        max-width: 100%;
        height: auto;
      }
    </style>
  </body>
</html>
