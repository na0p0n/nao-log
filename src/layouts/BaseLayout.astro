---
interface Props {
  title: string;
  description?: string;
  image?: string;
  pubDate?: Date;
  updatedDate?: Date;
  type?: 'website' | 'article';
  tags?: string[];
}

const {
  title,
  description,
  image,
  pubDate,
  updatedDate,
  type = 'website',
  tags = [],
} = Astro.props;

const siteName = 'Nao Log';
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;

// base: '/nao-log' なので Astro.url.pathname はベースパスを含む
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// public/ 配下のアセットはデプロイ後にベースパス配下で配信される
const baseURL = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const siteWithBase = `${Astro.site?.toString().replace(/\/$/, '')}${baseURL}`;
const resolveAsset = (path: string) =>
  path.startsWith('http')
    ? path
    : new URL(path.replace(/^\//, ''), siteWithBase).toString();
const ogImage = resolveAsset(image ?? 'og-default.png');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${baseURL}favicon.svg`} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    {pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {tags.map((t) => <meta property="article:tag" content={t} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header>
      <nav>
        <a href={baseURL}><strong>{siteName}</strong></a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>© {new Date().getFullYear()} {siteName}</small>
    </footer>
    <style is:global>
      :root {
        --fg: #1a1a1a;
        --bg: #fafafa;
        --muted: #666;
        --accent: #0969da;
        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          "Hiragino Sans",
          "Noto Sans JP",
          sans-serif;
      }
      body {
        margin: 0;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.75;
      }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      header,
      footer {
        max-width: 720px;
        margin: 0 auto;
        padding: 1rem;
      }
      footer {
        color: var(--muted);
        border-top: 1px solid #eaeaea;
        margin-top: 4rem;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      h1,
      h2,
      h3 {
        line-height: 1.3;
      }
      pre {
        padding: 1rem;
        border-radius: 6px;
        overflow-x: auto;
      }
      code {
        font-family: "SFMono-Regular", Consolas, monospace;
        font-size: 0.9em;
      }
      article time {
        color: var(--muted);
        font-size: 0.9em;
      }
    </style>
  </body>
</html>
